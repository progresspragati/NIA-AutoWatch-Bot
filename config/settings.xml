<?xml version="1.0" encoding="UTF-8"?>
<Settings>
    <!-- MODE SETTINGS -->
    <!-- Set to 'true' to only scan courses without watching videos -->
    <ScanOnlyMode>false</ScanOnlyMode>

    <!-- AUTOMATION LOGIC -->
    <!-- Instantly skip to the end of videos (true/false) -->
    <FastForward>false</FastForward>
    <!-- Keep the automation silent (true/false) -->
    <MuteAudio>true</MuteAudio>
    <!-- Re-watch videos even if they are already marked 'Done' (true/false) -->
    <ProcessCompletedVideos>false</ProcessCompletedVideos>

    <!-- PERFORMANCE & SCALE -->
    <!-- Number of different user accounts to process at once (1-5) -->
    <ConcurrentUsers>1</ConcurrentUsers>
    <!-- Number of videos per user to play simultaneously (1-10) -->
    <VideosPerUser>1</VideosPerUser>

    <!-- BROWSER & CONNECTION -->
    <!-- Run browser hidden in the background (true/false) -->
    <HideBrowser>false</HideBrowser>
    <!-- Seconds to wait for page elements to load -->
    <WaitTimeout>15</WaitTimeout>
    <!-- Max times to check for video completion per lesson -->
    <MaxCompletionChecks>500</MaxCompletionChecks>

    <!-- DATA SOURCES -->
    <!-- Name of the CSV file in config/ folder -->
    <CredentialFile>users.csv</CredentialFile>
</Settings>
